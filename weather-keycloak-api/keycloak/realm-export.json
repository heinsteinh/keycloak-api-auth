{
  "realm": "weather",
  "enabled": true,
  "displayName": "Weather Learning Realm",

  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "loginTheme": "weather",

  "roles": {
    "realm": [
      {
        "name": "weather:read",
        "description": "Can read weather data"
      },
      {
        "name": "weather:admin",
        "description": "Can access weather admin endpoints"
      }
    ]
  },

  "clients": [
    {
      "clientId": "weather-api",
      "name": "Weather API Local Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,

      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],

      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300"
      },

      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "weather-frontend",
      "name": "Weather Frontend (React/Vite)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,

      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],

      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      },

      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],

  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Weather",
      "credentials": [
        {
          "type": "password",
          "value": "Password123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "weather:read"
      ]
    },
    {
      "username": "admin-user",
      "enabled": true,
      "email": "admin-user@example.com",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Weather",
      "credentials": [
        {
          "type": "password",
          "value": "Password123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "weather:read",
        "weather:admin"
      ]
    }
  ]
}